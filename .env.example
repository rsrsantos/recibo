# ====================================================================
# Modelo de variáveis de ambiente do Santo Recibo.
# Copie para .env e preencha com os valores reais:
#     cp .env.example .env
# O arquivo .env NÃO deve ser versionado (já está no .gitignore).
# ====================================================================

# Perfil ativo: dev | homolog | prod
SPRING_PROFILES_ACTIVE=homolog

# --- Banco de dados ---
DB_NAME=recibo
DB_USERNAME=recibo
DB_PASSWORD=TROQUE_POR_UMA_SENHA_FORTE
# Porta do PostgreSQL exposta no host (interno sempre 5432).
DB_PORT=5432

# Porta externa pela qual a aplicação será acessada no host.
APP_PORT=8080

# --- Aplicação ---
# URL pública, SEM barra no final. Em homologação, o domínio/IP do servidor.
# Ex.: http://meu-servidor:8080/recibo  ou  https://homolog.dominio.com.br/recibo
APP_URL_BASE=http://localhost:8080/recibo

# WhatsApp de suporte (só dígitos: país+DDD+número). Vazio = botão oculto.
APP_WHATSAPP=5595981039567

# --- E-mail (Gmail: use uma "Senha de app", não a senha normal) ---
MAIL_HOST=smtp.gmail.com
MAIL_PORT=465
MAIL_USERNAME=santorecibo@gmail.com
MAIL_PASSWORD=
MAIL_REMETENTE=Santo Recibo <santorecibo@gmail.com>

# --- Google OAuth2 (login com Google) ---
# URI de redirecionamento autorizado no Google Console:
#   {APP_URL_BASE}/login/oauth2/code/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Mercado Pago ---
# Credenciais de TESTE têm prefixo TEST-; produção não tem.
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
